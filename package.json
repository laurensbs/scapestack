{
  "name": "osrs-bank-organizer",
  "version": "0.2.0",
  "description": "Smart OSRS bank auto-organizer with RuneLite Bank Tags + Bank Memory support",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack --port 4173",
    "build": "next build",
    "start": "next start --port 4173",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "audit:next": "tsx scripts/audit-next.ts",
    "build:sprites": "node scripts/build-skill-sprites.mjs && node scripts/build-boss-sprites.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "geist": "^1.7.0",
    "lucide-react": "^0.475.0",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/ui": "^4.1.6",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "typescript": "^5",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=20"
  }
}
