{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://www.scapestack.org/schemas/outcome-gate-v1.json",
  "title": "Scapestack outcome gate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "phase",
    "capturedAt",
    "baselineCommit",
    "launchReady",
    "release",
    "gates",
    "categories"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "phase": { "type": "string", "pattern": "^ODR-[0-9]{2}$" },
    "capturedAt": { "type": "string", "format": "date-time" },
    "baselineCommit": { "type": "string", "pattern": "^[0-9a-f]{7,40}$" },
    "launchReady": { "type": "boolean" },
    "release": {
      "type": "object",
      "additionalProperties": false,
      "required": ["publishedVersion", "contractVersion", "sourceCommit", "pluginHubVerified"],
      "properties": {
        "publishedVersion": { "type": "string" },
        "contractVersion": { "type": "integer", "minimum": 1 },
        "sourceCommit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "pluginHubVerified": { "type": "boolean" }
      }
    },
    "gates": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ci", "browser", "production", "pluginRelease", "pluginIntegration"],
      "properties": {
        "ci": { "$ref": "#/$defs/gate" },
        "browser": { "$ref": "#/$defs/gate" },
        "production": { "$ref": "#/$defs/gate" },
        "pluginRelease": { "$ref": "#/$defs/gate" },
        "pluginIntegration": {
          "allOf": [
            { "$ref": "#/$defs/gate" },
            {
              "type": "object",
              "required": ["executed", "tests", "skipped", "isolatedPersistence"],
              "properties": {
                "executed": { "const": true },
                "tests": { "type": "integer", "minimum": 1 },
                "skipped": { "const": 0 },
                "isolatedPersistence": { "const": true }
              }
            }
          ]
        }
      }
    },
    "categories": {
      "type": "array",
      "minItems": 18,
      "items": { "$ref": "#/$defs/category" }
    }
  },
  "$defs": {
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "artifact", "reason"],
      "properties": {
        "level": { "type": "integer", "minimum": 1, "maximum": 8 },
        "artifact": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 }
      }
    },
    "gate": {
      "type": "object",
      "required": ["passed", "reason", "evidence"],
      "properties": {
        "passed": { "type": "boolean" },
        "reason": { "type": "string", "minLength": 1 },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/evidence" }
        }
      }
    },
    "category": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "score", "target", "passed", "reason", "evidence"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "score": { "type": "number", "minimum": 0, "maximum": 10 },
        "target": { "type": "number", "minimum": 0, "maximum": 10 },
        "passed": { "type": "boolean" },
        "reason": { "type": "string", "minLength": 1 },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/evidence" }
        }
      }
    }
  }
}
